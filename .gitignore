# Project-specific
# Large data and model files should live outside the repo (Zenodo / releases).
# Note: data/examples/ is the synthetic mini dataset shipped for the
# quickstart and MUST stay tracked. The Data/ rule below would otherwise
# swallow it on case-insensitive filesystems (Windows, macOS APFS default),
# so we explicitly re-include data/examples/ via the negation rules below.
Data/
GEMs/
HPLC_results/
Mono_culture_ODs/
*.sbml
*.xml.gz
*.mat

# Re-include the shipped quickstart dataset (must come after the Data/ rule).
!data/
/data/*
!/data/examples/
!/data/examples/**

# But keep large SBML models out of git — they're fetched on demand by
# `scripts/fetch_realistic_example.py`. Tiny CSV/markdown stay tracked.
data/examples/realistic/*.xml

# Documentation build output
site/
site-zh/

# CLI run artifacts (fit/simulate/interactions outputs)
results/

# Secrets / local overrides
.env
.env.*
!.env.example

# Claude Code per-user settings (plugin choices vary per developer — don't commit either)
.claude/settings.json
.claude/settings.local.json

# R session history (any directory)
.Rhistory
**/.Rhistory

# Personal launcher scripts (reads API key from %USERPROFILE%\.anthropic_key — never commit)
start-claude.ps1

# Personal development log (Chinese filename)
开发日志.md

# Skills installed via `npx skills add ...` (per-developer tooling, not project code).
# The installer drops files in many places: real files in .agents/, plus symlinks
# under skills/, .claude/skills/, and a per-agent dir for every supported AI agent.
.agents/
/skills/
skills-lock.json
.claude/skills/
# Per-agent symlink directories created by the skills installer
.adal/
.aider-desk/
.augment/
.bob/
.codeartsdoer/
.codebuddy/
.codemaker/
.codestudio/
.commandcode/
.continue/
.cortex/
.crush/
.devin/
.factory/
.forge/
