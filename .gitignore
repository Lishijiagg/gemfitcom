# OS
.DS_Store
Thumbs.db

# Project-specific
# Large data and model files should live outside the repo (Zenodo / releases).
# Note: data/examples/ is the synthetic mini dataset shipped for the
# quickstart and MUST stay tracked. The Data/ rule below would otherwise
# swallow it on case-insensitive filesystems (Windows, macOS APFS default),
# so we explicitly re-include data/examples/ via the negation rules below.
Data/
GEMs/
HPLC_results/
Mono_culture_ODs/
*.sbml
*.xml.gz
*.mat

# Re-include the shipped quickstart dataset (must come after the Data/ rule).
!data/
/data/*
!/data/examples/
!/data/examples/**

# Documentation build output
site/
site-zh/

# Secrets / local overrides
.env
.env.*
!.env.example

# Claude Code per-user local settings (project-shared settings.json is fine to commit)
.claude/settings.local.json
